[global]
	width = (0, 500)
	height = (0, 1000)
    timeout = 2
    font = Monospace 10
    frame_width = 0
    separator_height = 10

[urgency_low]
    background = "#282828"
    foreground = "#ebdbb2"

[urgency_normal]
    background = "#282828"
    foreground = "#ebdbb2"

[urgency_critical]
    background = "#FF0000"
    foreground = "#ebdbb2"
    timeout = 0