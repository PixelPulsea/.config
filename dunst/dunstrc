[global]
	width = (0, 500)
	height = (0, 1000)
    timeout = 2
    font = Monospace 10
    frame_width = 0
    separator_height = 10

[urgency_low]
    background = "#3D3D3D"
    foreground = "#ffffff"

[urgency_normal]
    background = "#3D3D3D"
    foreground = "#ffffff"

[urgency_critical]
    background = "#000000"
    foreground = "#ebdbb2"
    timeout = 0