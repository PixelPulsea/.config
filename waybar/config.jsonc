// -*- mode: jsonc -*-
{
    // "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    //"height": 34, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    "margin-top": 0,
	"height": 27,
    //"width": 1585,
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
    ],
    "modules-right": [
        "tray",
		"custom/seperator",
        "battery",
	"custom/seperator",
	"clock"
    ],
    // Modules configuration
     "hyprland/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{icon}",
         "format-icons": {
            "1": "Edit",
            "2": "Web",
            "3": "Extra",
            "4": "4",
            "5": "5",
            //"urgent": "ïپھ",
            //"focused": "ï†’",
            //"default": "ï„‘"
	 },
	 "persistent-workspaces": {
		"*": 3
     }
    },

    "tray": {
        "spacing": 7,
        "icon-size": 16
    },

    "power-profiles-daemon": {
	    "format": "{icon}",
	    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
	    "tooltip": true,
	    "format-icons": {
		    "default": "ïƒ§",
		    "performance": "ïƒ§",
		    "balanced": "ï‰ژ",
		    "power-saver": "ïپ¬"
	    }
    },
    
    "group/popuptray": {
        "orientation": "horizontal",
        "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "click-to-reveal": false,
        "transition-left-to-right": true
        },
        "modules": [
            "custom/arrow",
            "tray"
        ]
    },

    "cava": {
        // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
        "framerate": 60,
        "autosens": 1,
        //"sensitivity": 20,
        "bars": 16,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 20000,
        "hide_on_silence": false,
        "method": "pulse",
        "source": "auto",
        "stereo": false,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.20,
        "input_delay": 1,
        "format-icons": ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ" ]
    },

    "clock": {
        // "timezone": "America/New_York",
	"format": "{:%I:%M %p}",
	"tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
	"calendar": {
		"mode"          : "month",
		"mode-mon-col"  : 3,
		"weeks-pos"     : "right",
		"format": {
			"months":     "<span color='#ffead3'><b>{}</b></span>",
			"days":       "<span color='#ffffff'><b>{}</b></span>",
			"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
			"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
			"today":      "<span color='#ff6699'><b>{}</b></span>"
	        }
	    }
    },

    "battery": {
        "states": {
            //"good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": " {icon} {capacity}%",
        "format-full": " {icon} {capacity}%",
        "format-charging": " َ°‚„ {capacity}%",
        "format-plugged": " ï‡¦ {capacity}%",
        "tooltip-format": "{timeTo}: {cycles} Cycles",
	    "interval": 1,
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "{icon}",
        "format-linked": "ï‚¬",
        "tooltip-format": "{essid}",
	    "interval": 1,
        "format-disconnected": "َ°¤­",
	    "on-click": "alacritty -e nmtui",
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"] 
    },

    "custom/": {
        "exec": "awk '{printf \"%.2f W\\n\", $1/1000000}' /sys/class/power_supply/BAT0/power_now", 
        "interval": 1,
        "format": "{}",
        "tooltip": false
    },

    "custom/notification": {
        "format": "ïƒ³",
        "tooltip": false,
        "on-click": "swaync-client -t"
    },

    "custom/seperator": {
        "format": "||",
        "tooltip": false
    },

    "custom/arrow": {
        "format": "ï„„",
        "tooltip": false
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "َ°–پ",
        "format-muted": "َ°–پ",
        "format-source": "{volume}% ï„°",
        "format-source-muted": "ï„±",
	    "scroll-step": 0.7,
	    "max-volume": 150,
        "reverse-scrolling": true,
        "format-icons": {
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
	    "tooltip-format": "Volume: {volume}%"
    }

}
